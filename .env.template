# ==============================================================================
# COVENANT PROTOCOL: MASTER SYSTEM ENVIRONMENT TEMPLATE
# Instructions: Copy this file to '.env' inside both /backend and /frontend 
# directories and fill in your private developer configurations.
# ==============================================================================

# --- CENTRAL RUNTIME PORTS ---
PORT=8080
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# --- CASPER.CLICK CONFIGURATIONS (SDK SIGNATURE PROVIDER) ---
CSPR_CLICK_KEY=your_cspr_click_developer_key_here
CSPR_CLICK_APP_ID=your_cspr_click_app_id_here

# --- CASPER.CLOUD CONFIGURATIONS (NODE TELEMETRY METRICS) ---
CSPR_CLOUD_API_KEY=your_cspr_cloud_api_key_here

# --- SUPABASE POSTGRESQL DATABASE POOLS ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_publishable_key_here
SUPABASE_SECRET_KEY=sb_secret_your_secret_key_here
SUPABASE_JWKS_URL=https://your-project-id.supabase.co/auth/v1/.well-known/jwks.json

# PgBouncer pooled URL (Use Port 6543 with pgbouncer=true for transactions)
DATABASE_URL="postgresql://postgres.your-project-id:your_percent_encoded_password@aws-1-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection URL (Use Port 5432 for GORM migrations and structural setups)
DIRECT_URL="postgresql://postgres.your-project-id:your_percent_encoded_password@aws-1-eu-north-1.pooler.supabase.com:5432/postgres"

# --- GOOGLE GEMINI AI API (CASCADING AUDIT LAYER) ---
GEMINI_API_KEY=your_google_gemini_api_key_here

# --- TELEGRAM DECENTRALIZED NOTIFICATION BOT ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ==============================================================================
# CASPER TESTNET SMART CONTRACT HASHES
# Note: Ensure contract hashes are prefixed with 'hash-' for Go client alignment
# ==============================================================================
CONTRACT_HASH_AGENT_REGISTRY=hash-your_deployed_registry_contract_hash_here
CONTRACT_HASH_REPUTATION=hash-your_deployed_reputation_contract_hash_here
CONTRACT_HASH_CREDIT=hash-your_deployed_credit_contract_hash_here
CONTRACT_HASH_PAYMENT=hash-your_deployed_payment_contract_hash_here

# --- BACKGROUND AI SWARM WORKER TICKERS ---
# Configured as time durations (e.g. 15s, 1m, 1h)
SWARM_REPUTATION_INTERVAL=15s
SWARM_CREDIT_INTERVAL=20s
SWARM_RISK_INTERVAL=30s